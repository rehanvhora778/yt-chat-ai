# ===== YT Chat GenAI - Backend Environment Variables =====
# Copy this file to ".env" and fill in your own values.

# Flask
FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-string
PORT=5000

# JWT Authentication
JWT_SECRET=change-this-jwt-secret-too
JWT_EXPIRY_HOURS=24

# MongoDB Atlas connection string
# Example: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=your-mongodb-atlas-connection-string
MONGO_DB_NAME=yt_chat_genai

# Groq API key — FREE, high limits, used for text generation + audio.
# Get one at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
# Auto-used when GROQ_MODEL hits a free-tier limit. Needs a high per-minute token
# limit to accept a full transcript (8b-instant's 6k TPM is too small).
GROQ_FALLBACK_MODEL=openai/gpt-oss-120b
GROQ_WHISPER_MODEL=whisper-large-v3

# Google Gemini API key  (https://aistudio.google.com/app/apikey)
# Optional when GROQ_API_KEY is set. Used for embeddings if present; otherwise
# embeddings run locally (fastembed), so this can be left blank.
GOOGLE_API_KEY=your-google-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite
EMBEDDING_MODEL=models/gemini-embedding-001

# FAISS local index storage folder
FAISS_STORE_PATH=faiss_store

# Comma separated list of allowed frontend origins (CORS)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
